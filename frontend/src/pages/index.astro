---
import Layout from "../layouts/Layout.astro";
import portfolio from "../content/portfolio-content.json";

const projectLinkClass = (kind = "secondary") =>
  kind === "primary"
    ? "inline-flex items-center rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
    : "inline-flex items-center rounded-full border border-zinc-700 px-4 py-2 text-sm font-semibold text-neutral-200 transition-colors hover:border-neutral-500 hover:text-white";

const profileLinkClass =
  "inline-flex items-center rounded-full border border-zinc-700 bg-zinc-800/60 px-4 py-2 text-sm font-semibold text-neutral-200 transition-colors hover:border-primary/50 hover:text-white hover:bg-zinc-800";

const currentExperience = portfolio.experienceHighlights.filter(
  (item) => item.current,
);
const previousExperience = portfolio.experienceHighlights.filter(
  (item) => !item.current,
);
---

<Layout
  title={portfolio.site.metaTitle}
  description={portfolio.site.metaDescription}
  url={portfolio.site.url}
  image={portfolio.site.ogImage}
>
  <!-- 🌊 Background Effects -->
  <div
    class="fixed inset-0 bg-gradient-to-br from-neutral-900 via-zinc-900 to-black -z-10"
  >
  </div>
  <div
    class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent -z-10"
  >
  </div>

  <!-- 👁️ Floating Visitor Counter -->
  <div
    id="visitor_counter_pill"
    class="fixed bottom-6 right-6 inline-flex items-center gap-2 bg-zinc-900/40 border border-zinc-800/50 backdrop-blur-md px-4 py-2 rounded-full shadow-2xl select-none hover:border-zinc-700 hover:scale-105 transition-all duration-300 z-50 font-sans"
  >
    <!-- Pulse Glow Dot -->
    <span class="relative flex h-2 w-2 ml-1">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
      ></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
      ></span>
    </span>

    <!-- Icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-4 w-4 text-neutral-400"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
      ></path>
    </svg>

    <span class="text-xs font-semibold tracking-wide text-neutral-400"
      >VIEWS</span
    >
    <span
      id="visitor_count_display"
      class="font-bold text-sm bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent"
      >...</span
    >
  </div>

  <main
    class="max-w-5xl mx-auto px-6 pb-24 space-y-14 md:space-y-16 mt-8 md:mt-10"
  >
    <section class="hero text-center py-8">
      <div class="hero-content flex-col">
        <div class="avatar online">
          <div
            class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 shadow-2xl"
          >
            <img src="/photo.jpeg" alt={`${portfolio.site.name} avatar`} />
          </div>
        </div>
        <div class="max-w-3xl">
          <h1
            class="text-5xl font-extrabold tracking-tight text-white mt-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
          >
            {portfolio.site.name}
          </h1>
          <p class="text-2xl text-neutral-200 font-semibold mt-4 leading-tight">
            {portfolio.site.headline}
          </p>
          <p
            class="text-base text-neutral-400 mt-5 max-w-2xl mx-auto leading-relaxed"
          >
            {portfolio.hero.intro}
          </p>
        </div>
      </div>
    </section>

    <section>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <article
          class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl"
        >
          <div class="card-body">
            <h2 class="card-title text-white text-2xl">About Me</h2>
            <p class="text-neutral-400 leading-relaxed">
              {portfolio.hero.about}
            </p>
          </div>
        </article>
        <article
          class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl"
        >
          <div class="card-body">
            <h2 class="card-title text-white text-2xl">Current Focus</h2>
            <p class="text-neutral-400 leading-relaxed">
              {portfolio.hero.focus}
            </p>
          </div>
        </article>
      </div>
    </section>

    <section id="projects">
      <h2
        class="text-2xl font-bold text-white mb-6 border-b border-neutral-800 pb-2"
      >
        Selected Projects
      </h2>
      <p class="max-w-3xl text-neutral-400 leading-relaxed mb-7">
        {portfolio.projectsIntro}
      </p>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        {
          portfolio.projects
            .filter((project) => !project.hide)
            .map((project) => (
              <article
                class:list={[
                  "card rounded-xl shadow-xl transition-all",
                  project.featured
                    ? "bg-gradient-to-br from-zinc-900 via-zinc-900 to-zinc-950 border border-primary/30 hover:border-primary/50 lg:col-span-3"
                    : "bg-zinc-900 border border-neutral-800 hover:border-neutral-700",
                ]}
              >
                <div class="card-body">
                  {project.featured && (
                    <p class="text-xs uppercase tracking-[0.24em] text-primary/80">
                      Featured Project
                    </p>
                  )}
                  {project.featuredNote && (
                    <p class="mt-2 text-sm font-semibold text-primary">
                      {project.featuredNote}
                    </p>
                  )}
                  <h3
                    class:list={[
                      "card-title text-white",
                      project.featured ? "text-2xl mt-2" : "text-xl",
                    ]}
                  >
                    {project.name}
                  </h3>
                  <p
                    class:list={[
                      "text-neutral-400 leading-relaxed",
                      project.featured ? "text-base" : "text-sm",
                    ]}
                  >
                    {project.summary}
                  </p>
                  <div class="flex flex-wrap gap-2 mt-3">
                    {project.stack.map((item) => (
                      <span class="badge badge-neutral bg-zinc-800/80 border border-zinc-700/50 rounded-md font-semibold">
                        {item}
                      </span>
                    ))}
                  </div>
                  {project.links && (
                    <div class="mt-5 flex flex-wrap gap-3">
                      {project.links.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noreferrer"
                          class={projectLinkClass(link.kind)}
                        >
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
        }
      </div>
    </section>

    <section>
      <h2
        class="text-2xl font-bold text-white mb-6 border-b border-neutral-800 pb-2"
      >
        Experience Highlights
      </h2>
      <div class="space-y-7">
        <div>
          <p class="text-sm uppercase tracking-[0.24em] text-neutral-500 mb-4">
            Current
          </p>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            {
              currentExperience.map((item) => (
                <article class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl hover:border-neutral-700 transition-all">
                  <div class="card-body">
                    <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">
                      {item.period}
                    </p>
                    <h3 class="card-title text-white text-xl">{item.role}</h3>
                    {item.companyUrl ? (
                      <a
                        href={item.companyUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="text-sm font-semibold text-primary hover:text-white transition-colors"
                      >
                        {item.company}
                      </a>
                    ) : (
                      <p class="text-sm font-semibold text-primary">
                        {item.company}
                      </p>
                    )}
                    <p class="text-sm text-neutral-400 leading-relaxed">
                      {item.summary}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
        <div>
          <p class="text-sm uppercase tracking-[0.24em] text-neutral-500 mb-4">
            Previous
          </p>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            {
              previousExperience.map((item) => (
                <article class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl hover:border-neutral-700 transition-all">
                  <div class="card-body">
                    <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">
                      {item.period}
                    </p>
                    <h3 class="card-title text-white text-xl">{item.role}</h3>
                    {item.companyUrl ? (
                      <a
                        href={item.companyUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="text-sm font-semibold text-primary hover:text-white transition-colors"
                      >
                        {item.company}
                      </a>
                    ) : (
                      <p class="text-sm font-semibold text-primary">
                        {item.company}
                      </p>
                    )}
                    <p class="text-sm text-neutral-400 leading-relaxed">
                      {item.summary}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2
        class="text-2xl font-bold text-white mb-6 border-b border-neutral-800 pb-2"
      >
        Capabilities
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {
          portfolio.capabilities.map((group) => (
            <article class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl hover:border-neutral-700 transition-all">
              <div class="card-body">
                <h3 class="card-title text-white text-xl">{group.name}</h3>
                <div class="flex flex-wrap gap-2 mt-2">
                  {group.items.map((item) => (
                    <span class="badge badge-lg badge-neutral bg-zinc-800/80 hover:bg-zinc-700 transition-all font-semibold rounded-md border border-zinc-700/50">
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2
        class="text-2xl font-bold text-white mb-6 border-b border-neutral-800 pb-2"
      >
        Certification
      </h2>
      <div class="grid grid-cols-1 gap-5">
        {
          portfolio.certifications.map((certification) => (
            <article class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl hover:border-neutral-700 transition-all">
              <div class="card-body">
                <h3 class="card-title text-white text-xl">
                  {certification.name}
                </h3>
                <a
                  href={certification.verifyUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="text-sm font-semibold text-primary hover:text-white transition-colors"
                >
                  {certification.issuer}
                </a>
                <p class="text-sm text-neutral-400">
                  Issued {certification.issued} • Expires{" "}
                  {certification.expires}
                </p>
                <div class="mt-4">
                  <a
                    href={certification.verifyUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center rounded-full border border-zinc-700 px-4 py-2 text-sm font-semibold text-neutral-200 transition-colors hover:border-primary/50 hover:text-white"
                  >
                    Verify on Credly
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contact">
      <h2
        class="text-2xl font-bold text-white mb-6 border-b border-neutral-800 pb-2"
      >
        Contact
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <article
          class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl"
        >
          <div class="card-body">
            <p class="text-sm uppercase tracking-[0.24em] text-neutral-500">
              Let's Work Together
            </p>
            <p class="text-sm text-neutral-400 leading-relaxed">
              {portfolio.contact.cta}
            </p>
            <a
              href={`mailto:${portfolio.contact.email}`}
              class="text-lg font-semibold text-white hover:text-primary transition-colors mt-3"
            >
              {portfolio.contact.email}
            </a>
          </div>
        </article>
        <article
          class="card bg-zinc-900 border border-neutral-800 rounded-xl shadow-xl"
        >
          <div class="card-body">
            <p class="text-sm uppercase tracking-[0.24em] text-neutral-500">
              Profiles
            </p>
            <div class="flex flex-wrap gap-3 mt-3">
              {
                portfolio.contact.profiles.map((profile) => (
                  <a
                    href={profile.href}
                    target="_blank"
                    rel="noreferrer"
                    class={profileLinkClass}
                  >
                    {profile.label}
                  </a>
                ))
              }
            </div>
          </div>
        </article>
      </div>
    </section>
  </main>

  <!-- 📝 Footer -->
  <footer
    class="footer footer-center p-10 bg-neutral-900/50 backdrop-blur-md text-neutral-500 border-t border-neutral-800 mt-20"
  >
    <div>
      <p class="font-bold tracking-wide">{portfolio.site.name} &copy; 2026</p>
    </div>
  </footer>

  <script>
    const counterElement = document.getElementById("visitor_count_display");
    const apiBaseUrl = import.meta.env.PUBLIC_API_URL;

    if (counterElement && apiBaseUrl) {
      fetch(`${apiBaseUrl}/count`, { method: "POST" })
        .then((r) => r.json())
        .then((data) => {
          counterElement.innerText = data.count;
        })
        .catch(() => {
          counterElement.innerText = "Unavailable";
        });
    } else {
      counterElement?.replaceChildren("Offline");
    }
  </script>
</Layout>
